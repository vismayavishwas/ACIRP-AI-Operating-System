# ==============================================================================
# ACIRP - Environment Configurations Example
# ==============================================================================
# Copy this file to `.env` in the same directory and fill in your actual keys.

# 🧠 Core Gemini API Key (Required for Perception & Verification Agents)
# Get your key from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# 💾 Database Provider Configuration
# Supported options: 'json' (local file db) or 'firebase' (Firestore + Storage)
DB_PROVIDER=json

# 🤝 Mem0 Memory Platform Credentials (Optional - Used on 'unstop' branch)
MEM0_API_KEY=your_mem0_api_key_here

# 🔥 Firebase Storage & Firestore Credentials (Optional - Used when DB_PROVIDER=firebase)
# Default (Google) Credentials
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket.appspot.com
# Provide the absolute path to your service account certificate or stringified JSON dict
FIREBASE_CREDENTIALS=serviceAccountKey.json

# Unstop Competition-specific Firebase Credentials (Optional - Used for Unstop contexts)
FIREBASE_PROJECT_ID_UNSTOP=your_unstop_firebase_project_id
FIREBASE_CREDENTIALS_UNSTOP=serviceAccountKey_unstop.json

# 🌐 Server Settings
PORT=8000
